import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int valor;

        for (int i = 1; i <= 5; i++) {

            System.out.print("Digite um valor: ");
            valor = sc.nextInt();

            System.out.println("Dobro: " + (valor * 2));
        }

        sc.close();
    }
}
